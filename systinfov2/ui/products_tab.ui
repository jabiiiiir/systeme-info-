<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ProductsTab</class>
 <widget class="QWidget" name="ProductsTab">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>900</width><height>600</height></rect>
  </property>
  <layout class="QVBoxLayout" name="main_layout">
   <item>
    <widget class="QSplitter" name="splitter">
     <property name="orientation"><enum>Qt::Horizontal</enum></property>
     <!-- Panneau gauche : liste des produits -->
     <widget class="QWidget" name="left_panel">
      <layout class="QVBoxLayout" name="left_vbox">
       <item>
        <widget class="QLabel" name="lbl_products">
         <property name="text"><string>Produits :</string></property>
        </widget>
       </item>
       <item>
        <widget class="QListWidget" name="list_products"/>
       </item>
       <item>
        <layout class="QHBoxLayout" name="prod_btn_row">
         <item>
          <widget class="QLineEdit" name="inp_prod_name">
           <property name="placeholderText"><string>Nom du produit</string></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_add_prod"><property name="text"><string>Ajouter</string></property></widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_ren_prod"><property name="text"><string>Renommer</string></property></widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_del_prod"><property name="text"><string>Supprimer</string></property></widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
     <!-- Panneau droit : étapes du produit -->
     <widget class="QWidget" name="right_panel">
      <layout class="QVBoxLayout" name="right_vbox">
       <item>
        <widget class="QLabel" name="lbl_tasks">
         <property name="text"><string>Étapes du produit sélectionné :</string></property>
        </widget>
       </item>
       <item>
        <widget class="QTableWidget" name="table_tasks">
         <property name="editTriggers">
          <set>QAbstractItemView::NoEditTriggers</set>
         </property>
         <column><property name="text"><string>Ordre</string></property></column>
         <column><property name="text"><string>Machine</string></property></column>
         <column><property name="text"><string>Durée (min)</string></property></column>
         <column><property name="text"><string>Puissance (W)</string></property></column>
        </widget>
       </item>
       <item>
        <widget class="QGroupBox" name="grp_add_step">
         <property name="title"><string>Ajouter une étape</string></property>
         <layout class="QFormLayout" name="form_step">
          <item row="0" column="0">
           <widget class="QLabel" name="lbl_machine"><property name="text"><string>Machine :</string></property></widget>
          </item>
          <item row="0" column="1">
           <widget class="QComboBox" name="cmb_machine"/>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="lbl_duration"><property name="text"><string>Durée (min) :</string></property></widget>
          </item>
          <item row="1" column="1">
           <widget class="QSpinBox" name="spn_duration">
            <property name="minimum"><number>1</number></property>
            <property name="maximum"><number>9999</number></property>
            <property name="suffix"><string> min</string></property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="step_btn_row">
         <item>
          <widget class="QPushButton" name="btn_add_step">
           <property name="text"><string>Ajouter l'étape</string></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_del_step">
           <property name="text"><string>Supprimer l'étape sélectionnée</string></property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
    </widget>
   </item>
  </layout>
 </widget>
